---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CareSection from '../../components/CareSection.astro';
import { species } from '../../data/species';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');

const careSections = [
  {
    title: t('care.water.title'),
    text: t('care.water.text'),
    tip: t('care.water.tip'),
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  },
  {
    title: t('care.light.title'),
    text: t('care.light.text'),
    tip: t('care.light.tip'),
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  },
  {
    title: t('care.substrate.title'),
    text: t('care.substrate.text'),
    tip: t('care.substrate.tip'),
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/></svg>`,
  },
  {
    title: t('care.temperature.title'),
    text: t('care.temperature.text'),
    tip: t('care.temperature.tip'),
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>`,
  },
  {
    title: t('care.feeding.title'),
    text: t('care.feeding.text'),
    tip: t('care.feeding.tip'),
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 0 1 5 5v6a5 5 0 0 1-10 0V7a5 5 0 0 1 5-5z"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="10" x2="9" y2="10" stroke-width="2"/><line x1="15" y1="10" x2="15" y2="10" stroke-width="2"/></svg>`,
  },
  {
    title: t('care.humidity.title'),
    text: t('care.humidity.text'),
    tip: t('care.humidity.tip'),
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9z"/></svg>`,
  },
  {
    title: t('care.dormancy.title'),
    text: t('care.dormancy.text'),
    tip: t('care.dormancy.tip'),
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`,
  },
];
---

<BaseLayout
  title="Care Guide"
  description="Learn to care for carnivorous plants. Everything about water, light, substrate, temperature, feeding and dormancy."
  lang="en"
>
  <section class="care-hero">
    <div class="container">
      <p class="section-header__eyebrow reveal">Cultivation</p>
      <h1 class="care-hero__title reveal reveal--2">{t('care.title')}</h1>
      <p class="care-hero__subtitle reveal reveal--3">{t('care.subtitle')}</p>
      <div class="deco-line reveal reveal--4"></div>
    </div>
    <div class="care-hero__deco" aria-hidden="true">
      {Array.from({length: 30}).map((_, i) => (
        <div
          class="care-hero__cilium"
          style={`left: ${(i / 29) * 100}%; height: ${16 + Math.sin(i * 0.8) * 10}px; animation-delay: ${i * 0.06}s`}
        ></div>
      ))}
    </div>
  </section>

  <section class="care-content section">
    <div class="container">
      <div class="care-grid">
        {careSections.map((section, i) => (
          <CareSection
            title={section.title}
            text={section.text}
            tip={section.tip}
            icon={section.icon}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="care-table section--sm">
    <div class="container">
      <div class="section-header">
        <span class="section-header__eyebrow">Reference</span>
        <h2 class="section-header__title reveal">{t('care.compare.title')}</h2>
        <div class="section-header__line reveal"></div>
      </div>
      <div class="table-wrap reveal reveal--2">
        <table>
          <thead>
            <tr>
              <th>{t('care.compare.species')}</th>
              <th>{t('care.compare.light')}</th>
              <th>{t('care.compare.water')}</th>
              <th>{t('care.compare.humidity')}</th>
              <th>{t('care.compare.dormancy')}</th>
            </tr>
          </thead>
          <tbody>
            {species.map(sp => (
              <tr>
                <td>
                  <span class="table-name">{sp.nameEn}</span><br/>
                  <em class="table-sci">{sp.scientific}</em>
                </td>
                <td>{sp.light}</td>
                <td>{sp.water.split(' — ')[0]}</td>
                <td>{sp.humidity}</td>
                <td>{sp.dormancyEn}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .care-hero { padding: 8rem 0 3rem; position: relative; overflow: hidden; border-bottom: 1px solid rgba(74,92,26,0.12); }
  .care-hero__title { font-size: clamp(2.5rem, 5vw, 4.5rem); margin: 0.5rem 0 1rem; }
  .care-hero__subtitle { font-size: 1.05rem; color: var(--cream-dim); max-width: 60ch; margin-bottom: 2rem; }
  .care-hero__deco { position: absolute; bottom: 0; left: 0; right: 0; height: 32px; display: flex; align-items: flex-end; }
  .care-hero__cilium { position: absolute; bottom: 0; width: 1.5px; background: linear-gradient(0deg, var(--crimson) 0%, transparent 100%); animation: ciliumSway 2.5s ease-in-out infinite alternate; transform-origin: bottom; }
  @keyframes ciliumSway { from { transform: rotate(-4deg); } to { transform: rotate(4deg); } }
  .care-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; max-width: 900px; margin: 0 auto; }
  .table-wrap { overflow-x: auto; border: 1px solid rgba(74,92,26,0.15); }
  .table-name { font-family: 'EB Garamond', Georgia, serif; font-size: 0.95rem; color: var(--cream); }
  .table-sci { font-family: 'Cormorant Garamond', Georgia, serif; font-style: italic; font-size: 0.8rem; color: var(--crimson-mid); }
</style>
