---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SpeciesCard from '../../../components/SpeciesCard.astro';
import { species } from '../../../data/species';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
---

<BaseLayout
  title="Species Catalog"
  description="Botanical profiles of the main carnivorous plant species. Dionaea, Nepenthes, Sarracenia, Drosera and more."
  lang="en"
>
  <section class="species-hero">
    <div class="container">
      <p class="section-header__eyebrow reveal">Botany</p>
      <h1 class="species-hero__title reveal reveal--2">{t('species.title')}</h1>
      <p class="species-hero__subtitle reveal reveal--3">{t('species.subtitle')}</p>
    </div>
  </section>

  <section class="species-filters">
    <div class="container">
      <div class="filter-row reveal">
        <span class="filter-label">Filter:</span>
        <a href="#all" class="filter-btn filter-btn--active">{t('species.filter.all')}</a>
        <a href="#active" class="filter-btn">{t('species.filter.active')}</a>
        <a href="#passive" class="filter-btn">{t('species.filter.passive')}</a>
        <a href="#adhesive" class="filter-btn">{t('species.filter.adhesive')}</a>
      </div>
    </div>
  </section>

  <section class="species-content section">
    <div class="container">
      <div class="species-grid" id="all">
        {species.map((sp, i) => (
          <SpeciesCard species={sp} lang="en" index={i} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .species-hero { padding: 8rem 0 3rem; position: relative; border-bottom: 1px solid rgba(74,92,26,0.12); }
  .species-hero__title { font-size: clamp(2.5rem, 5vw, 4.5rem); margin: 0.5rem 0 1rem; }
  .species-hero__subtitle { font-size: 1.05rem; color: var(--cream-dim); max-width: 60ch; font-style: italic; font-family: 'Cormorant Garamond', Georgia, serif; }
  .species-filters { padding: 1.5rem 0; background: var(--bg-secondary); border-bottom: 1px solid rgba(74,92,26,0.1); position: sticky; top: 60px; z-index: 10; }
  .filter-row { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .filter-label { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream-muted); }
  .filter-btn { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 0.85rem; font-weight: 500; letter-spacing: 0.06em; color: var(--cream-dim); padding: 0.3rem 0.9rem; border: 1px solid rgba(255,255,255,0.08); text-decoration: none; transition: all 180ms ease; }
  .filter-btn:hover, .filter-btn--active { color: var(--green-light); border-color: var(--green-mid); background: rgba(74,92,26,0.1); }
  .species-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (max-width: 1024px) { .species-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .species-grid { grid-template-columns: 1fr; } }
</style>
