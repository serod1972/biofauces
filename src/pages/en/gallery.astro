---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryGrid from '../../components/GalleryGrid.astro';
import { species } from '../../data/species';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');

const galleryItems = species.flatMap(sp =>
  sp.images.map(img => ({
    src: img,
    alt: `${sp.nameEn} — ${sp.scientific}`,
    caption: `${sp.nameEn} · ${sp.scientific}`,
  }))
);
---

<BaseLayout
  title="Gallery"
  description="Photo gallery of carnivorous plants. Venus flytraps, Nepenthes, Sarracenia, Drosera and more."
  lang="en"
>
  <section class="gallery-hero">
    <div class="container">
      <p class="section-header__eyebrow reveal">Photography</p>
      <h1 class="gallery-hero__title reveal reveal--2">{t('gallery.title')}</h1>
      <p class="gallery-hero__subtitle reveal reveal--3">{t('gallery.subtitle')}</p>
    </div>
  </section>

  <section class="gallery-content section">
    <div class="container">
      <GalleryGrid items={galleryItems} />
    </div>
  </section>

  <section class="gallery-attribution section--sm">
    <div class="container">
      <p class="attribution-text">
        Photography <a href="https://unsplash.com" target="_blank" rel="noopener noreferrer">via Unsplash</a>.
        Photographers retain all rights to their work.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-hero { padding: 8rem 0 3rem; border-bottom: 1px solid rgba(74,92,26,0.12); }
  .gallery-hero__title { font-size: clamp(2.5rem, 5vw, 4.5rem); margin: 0.5rem 0 1rem; }
  .gallery-hero__subtitle { font-size: 1.1rem; color: var(--cream-dim); font-style: italic; font-family: 'Cormorant Garamond', Georgia, serif; max-width: 50ch; }
  .gallery-attribution { border-top: 1px solid rgba(255,255,255,0.05); padding: var(--space-lg) 0; }
  .attribution-text { font-size: 0.82rem; color: var(--cream-muted); text-align: center; max-width: none; }
  .attribution-text a { color: var(--cream-dim); transition: color 180ms ease; }
  .attribution-text a:hover { color: var(--green-light); }
</style>
